{
  "name": "jimaku",
  "version": "0.1.0",
  "description": "Chrome extension that translates Amazon Prime Video's English subtitles into Japanese using Claude and overlays them on the player",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky",
    "chrome": "'/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --user-data-dir=./.chrome-profile --load-extension=$(pwd)/dist --remote-debugging-port=9222 --no-first-run --no-default-browser-check https://www.primevideo.com",
    "chrome:build": "npm run build && npm run chrome"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.268",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
